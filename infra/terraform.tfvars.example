aws_region   = "us-east-1"
environment  = "dev"
app_image_tag = "latest"

# Hedera
hedera_network             = "testnet"
hedera_usdc_token_id       = "0.0.XXXXX"
hedera_escrow_contract_id  = "0.0.XXXXX"

# Oracle schedules (UTC)
# Weekly job: Tuesdays at 9am — after Monday Night Football scores are final
oracle_weekly_schedule = "cron(0 9 ? * TUE *)"
# Season-end job: Wednesdays at 9am — check for completed leagues weekly
oracle_season_schedule = "cron(0 9 ? * WED *)"

# Database
db_instance_class = "db.t4g.micro"
db_multi_az       = false   # set true for prod

# ECS
gateway_desired_count = 1
